# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Agency Module =====
# Anthropic Claude API key for content generation (with prompt caching)
# Get yours at: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-your_anthropic_api_key_here

# JWT secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-64-chars

# Admin account email (password set on first /api/agency/auth/admin-setup)
AGENCY_ADMIN_EMAIL=admin@youragency.com

# CORS allowed origins (comma-separated, no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000

# GDPR: days before inactive churned clients are auto-purged (default 90)
AGENCY_MAX_CONTENT_AGE_DAYS=90

# ── Gmail SMTP (outbound emails for lead outreach sequences) ──────────────────
# IMPORTANT: Use a Gmail APP PASSWORD, NOT your account password.
# Generate: myaccount.google.com → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_NAME=ContentAgency.ai

# ── Gmail IMAP (reply detection — polls every 15 min for lead replies) ────────
IMAP_HOST=imap.gmail.com
IMAP_USER=your-gmail@gmail.com
IMAP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Google Maps Places API (autonomous prospect scouting at 08:00 daily) ──────
# Enable "Places API" in console.cloud.google.com → APIs & Services
# Free tier: 28,500 requests/month
GOOGLE_MAPS_API_KEY=AIzaSy...

# ── Buffer API (publishes approved client content nightly at 23:00) ───────────
# Token: buffer.com/developers/apps → create app → copy access token
# Profile IDs: buffer.com/developers/api/profiles → copy _id for each channel
BUFFER_ACCESS_TOKEN=1/...
BUFFER_PROFILE_IDS={"linkedin":"64abc...","instagram":"64def...","facebook":"64ghi..."}

# ── LinkedIn local scripts (scripts/ directory — run on YOUR machine, not server) ─
# Only used by scripts/linkedin_scout.py and scripts/linkedin_sender.py
LINKEDIN_EMAIL=your-linkedin@email.com
LINKEDIN_PASSWORD=your-linkedin-password

# URL and auth token for the scripts to POST leads back to the platform
API_BASE_URL=http://localhost:3000
# Copy from browser: devtools → Application → Local Storage → agency_access_token
API_TOKEN=eyJ...